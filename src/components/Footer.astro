---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__container">

    <div class="footer__top">
      <a href="/" class="footer__logo" aria-label="IA-Médecin accueil">
        <img src="/ia-medecin-logo.svg" alt="IA-Médecin" class="footer__logo-img" />
      </a>
      <p class="footer__tagline">Le répertoire des technologies IA pour les médecins en France.</p>
    </div>

    <div class="footer__bottom">
      <span class="footer__copy">© {year} ia-medecin.com — Tous droits réservés</span>
      <nav class="footer__nav" aria-label="Liens de navigation">
        <a href="#solutions" class="footer__link">Solutions</a>
        <a href="#faq" class="footer__link">FAQ</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: #ffffff;
    border-top: 1px solid #f1f1f1;
    padding: 3rem 0 2rem;
  }

  .footer__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .footer__top {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer__logo {
    display: inline-flex;
    text-decoration: none;
  }

  .footer__logo-img {
    height: 26px;
    width: auto;
  }

  .footer__tagline {
    font-size: 0.9375rem;
    color: #64748b;
    line-height: 1.5;
    max-width: 380px;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid #f1f1f1;
    padding-top: 1.5rem;
  }

  .footer__copy {
    font-size: 0.875rem;
    color: #94a3b8;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .footer__nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    font-family: 'Switzer', system-ui, sans-serif;
    transition: color 0.15s ease;
  }

  .footer__link:hover {
    color: #2C1FEA;
  }

  @media (max-width: 600px) {
    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
