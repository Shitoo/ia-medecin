---
import { createClient } from '../prismicio';

const client = createClient();
const solutionDocs = await client.getAllByType('solution').catch(() => []);

const solutions = solutionDocs.map((doc) => ({
  name: doc.data.company_name as string,
  category: doc.data.category as string,
  description: doc.data.description as string,
  logo: (doc.data.logo as { url?: string })?.url || null,
  url: (doc.data.website_url as string) || null,
}));
---

<section class="solutions" id="solutions">
  <div class="solutions__container">

    <div class="solutions__header">
      <h2 class="solutions__title">Les solutions IA pour les médecins</h2>
      <p class="solutions__subtitle">Une sélection de solutions d'intelligence artificielle et de produits intégrant l'IA pour les médecins en France.</p>
    </div>

    {solutions.length === 0 && (
      <p class="solutions__empty">Aucune solution pour le moment. Ajoutez-en depuis le CMS Prismic.</p>
    )}

    <div class="solutions__grid">
      {solutions.map((solution) => (
        <a
          class="card"
          href={solution.url ?? '#'}
          target={solution.url ? '_blank' : undefined}
          rel="nofollow noopener noreferrer"
          aria-label={`Visiter le site de ${solution.name}`}
        >
          <div class="card__category">
            {solution.category}
          </div>

          <div class="card__logo">
            {solution.logo
              ? <img src={solution.logo} alt={`Logo ${solution.name}`} class="card__logo-img" />
              : <span class="card__initial">{(solution.name)?.[0] ?? '?'}</span>
            }
          </div>

          <h3 class="card__name">{solution.name}</h3>
          <p class="card__description">{solution.description}</p>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .solutions {
    background-color: #ffffff;
    padding: 5rem 0;
  }

  .solutions__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .solutions__header {
    margin-bottom: 2.5rem;
  }

  .solutions__title {
    font-size: 50px;
    font-weight: 500;
    color: #0f172a;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .solutions__subtitle {
    font-size: 1rem;
    color: #64748b;
    line-height: 1.6;
  }

  .solutions__empty {
    font-size: 0.9375rem;
    color: #94a3b8;
    padding: 2rem 0;
  }

  .solutions__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* Card */
  .card, a.card {
    text-decoration: none;
  }

  .card {
    background-color: #ffffff;
    border: 1px solid #e8e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    transition: background-image 0.2s ease;
    cursor: pointer;
  }

  .card:hover {
    background-image: radial-gradient(ellipse at 100% 50%, rgba(44, 31, 234, 0.15) 0%, transparent 70%);
  }

  .card__category {
    align-self: flex-start;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    background-color: #f8f8fc;
    border: 1px solid #e8e8f0;
    border-radius: 999px;
    padding: 0.25rem 0.625rem;
  }

  .card__logo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0.25rem 0;
    border: 1px solid #e8e8f0;
    background-color: #f8f8fc;
    overflow: hidden;
  }

  .card__logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card__initial {
    font-size: 1.5rem;
    font-weight: 600;
    font-family: 'Switzer', system-ui, sans-serif;
    color: #94a3b8;
  }

  .card__name {
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
    font-family: 'Switzer', system-ui, sans-serif;
  }

  .card__description {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.55;
  }

  @media (max-width: 1024px) {
    .solutions__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .solutions__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
