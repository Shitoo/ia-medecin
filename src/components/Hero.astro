<section class="hero">
  <div class="hero__container">
    <h1 class="hero__title">
      Toutes les technologies IA<br />pour les <span class="hero__title--accent">médecins</span>
    </h1>
    <p class="hero__description">
      Explorez les technologies d'intelligence artificielle pour les médecins,
      réunies et organisées pour vous.
    </p>
    <a href="#solutions" class="hero__cta">Découvrir les solutions</a>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    padding: calc(68px + 2rem) 2rem 2rem;
    text-align: center;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(44, 31, 234, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(44, 31, 234, 0.07) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 60%, transparent 100%);
    pointer-events: none;
  }

  .hero__container {
    max-width: 920px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .hero__title {
    font-size: 70px;
    font-weight: 500;
    line-height: 1.15;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .hero__title--accent {
    color: #2C1FEA;
  }

  .hero__description {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #475569;
    line-height: 1.6;
    max-width: 560px;
  }

  .hero__cta {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.875rem 2rem;
    background-color: #2C1FEA;
    color: #ffffff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
  }

  .hero__cta:hover {
    background-color: #2C1FEA;
  }
</style>
